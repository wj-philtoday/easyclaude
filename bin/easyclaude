#!/usr/bin/env bash
# easyclaude — claude code 멀티 세션 워크벤치
#
# 서브커맨드:
#   easyclaude [run]            서버 실행 (기본)
#   easyclaude install [opts]   설치 (sudo / --user / --no-systemd / --prefix)
#   easyclaude update           git pull + npm install + 프로세스 재기동
#   easyclaude tail <sid|uuid>  활성 세션 jsonl tail
#   easyclaude help             이 도움말
set -e
HERE="$(dirname "$(readlink -f "$0")")"
ROOT="$(dirname "$HERE")"
CMD="${1:-run}"

case "$CMD" in
  run|'')
    exec node "$ROOT/server/index.js" "${@:2}"
    ;;
  install)
    shift
    exec bash "$ROOT/install.sh" "$@"
    ;;
  update)
    shift
    exec bash "$ROOT/scripts/update.sh" "$@"
    ;;
  restart)
    shift
    exec bash "$ROOT/scripts/restart.sh" "$@"
    ;;
  tail)
    shift
    exec "$ROOT/bin/easyclaude-tail" "$@"
    ;;
  help|--help|-h)
    cat <<'EOF'
easyclaude — claude code 멀티 세션 워크벤치

사용:
  easyclaude [run]            서버 실행 (기본)
  easyclaude install [opts]   설치 (sudo / --user / --no-systemd / --prefix)
  easyclaude update           git pull + npm install + 프로세스 재기동
  easyclaude restart          ec 서버만 재기동 (자식 claude는 supervisor가 살림)
  easyclaude tail <sid|uuid>  활성 세션 jsonl tail
  easyclaude help             이 도움말
EOF
    ;;
  *)
    echo "unknown subcommand: $CMD" >&2
    echo "easyclaude help — 도움말" >&2
    exit 2
    ;;
esac
